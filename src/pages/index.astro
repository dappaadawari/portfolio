<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Adawari Dappa — Game Systems Engineer</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #0a0a0a;
    --bg2: #111111;
    --bg3: #181818;
    --border: #222222;
    --accent: #c8f060;
    --accent2: #60a0f0;
    --text: #e8e8e8;
    --muted: #666;
    --muted2: #444;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 48px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-logo span { color: var(--accent); }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(200,240,96,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(96,160,240,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.1s forwards;
  }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(52px, 8vw, 96px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.2s forwards;
  }

  .hero h1 .line2 {
    color: var(--muted2);
    display: block;
  }

  .hero-desc {
    max-width: 560px;
    color: #999;
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.35s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.45s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #0a0a0a;
    padding: 14px 28px;
    border-radius: 4px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary:hover { background: #d8ff70; transform: translateY(-1px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 14px 28px;
    border-radius: 4px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover { border-color: #444; color: var(--text); }

  .hero-stats {
    display: flex;
    gap: 48px;
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
    opacity: 0;
    animation: fadeUp 0.6s ease 0.55s forwards;
  }

  .stat-item {}
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
  }
  .stat-num span { color: var(--accent); }
  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* SECTION COMMON */
  section {
    padding: 100px 48px;
    border-top: 1px solid var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 64px;
  }

  .section-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  /* PROJECTS / CASE STUDIES */
  .projects-grid {
    display: grid;
    gap: 2px;
  }

  .case-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 40px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .case-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--accent);
    transition: height 0.3s ease;
  }

  .case-card:hover::before { height: 100%; }
  .case-card:hover { border-color: #333; background: var(--bg3); }

  .case-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .case-type {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(200,240,96,0.08);
    padding: 4px 10px;
    border-radius: 2px;
  }

  .case-type.blue {
    color: var(--accent2);
    background: rgba(96,160,240,0.08);
  }

  .case-date {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }

  .case-title {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    color: var(--text);
  }

  .case-subtitle {
    color: #888;
    font-size: 14px;
    line-height: 1.6;
    max-width: 620px;
  }

  .case-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 2px;
    letter-spacing: 0.04em;
  }

  .case-arrow {
    font-size: 20px;
    color: var(--muted2);
    transition: all 0.2s;
    margin-top: 4px;
  }

  .case-card:hover .case-arrow {
    color: var(--accent);
    transform: translate(3px, -3px);
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .skill-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
    transition: border-color 0.2s;
  }

  .skill-card:hover { border-color: #333; }

  .skill-icon {
    font-size: 24px;
    margin-bottom: 12px;
  }

  .skill-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 6px;
  }

  .skill-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  .skill-bar-wrap {
    margin-top: 14px;
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skill-bar {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about-text p {
    color: #999;
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .about-text p strong { color: var(--text); font-weight: 500; }

  .about-details {}

  .detail-block {
    border-left: 2px solid var(--border);
    padding-left: 20px;
    margin-bottom: 32px;
  }

  .detail-block:hover { border-color: var(--accent); }

  .detail-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .detail-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 4px;
  }

  .detail-sub {
    font-size: 13px;
    color: var(--muted);
  }

  /* CONTACT */
  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 80px 0;
  }

  .contact-inner h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 16px;
  }

  .contact-inner p {
    color: #888;
    font-size: 16px;
    margin-bottom: 40px;
    max-width: 440px;
  }

  .contact-links {
    display: flex;
    gap: 16px;
  }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 32px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  footer p {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* GRID LINE DECORATION */
  .grid-decoration {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* full-width border wrapper */
  .section-wrapper {
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .hero { padding: 100px 24px 60px; }
    section { padding: 64px 24px; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-stats { gap: 28px; flex-wrap: wrap; }
    .case-card { grid-template-columns: 1fr; }
    footer { padding: 24px; flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
</head>
<body>

<div class="grid-decoration"></div>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">AD<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#projects">projects</a></li>
    <li><a href="#skills">skills</a></li>
    <li><a href="#about">about</a></li>
    <li><a href="#contact">contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<div class="section-wrapper">
  <div style="max-width:1200px; margin:0 auto;">
    <div class="hero">
      <p class="hero-tag">// Game Systems Engineer</p>
      <h1>
        Adawari
        <span class="line2">Dappa.</span>
      </h1>
      <p class="hero-desc">
        I am a CS student at UT Dallas building client-server game systems in Lua and C++.
        I architect systems that are clean, scalable, resuable, and built to last.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">View Case Studies →</a>
        <a href="mailto:dappaadawari@gmail.com" class="btn-secondary">Get in Touch</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">6<span>+</span></div>
          <div class="stat-label">Game Systems Built</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">5<span>+</span></div>
          <div class="stat-label">Languages</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">2027</div>
          <div class="stat-label">UT Dallas Grad</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">1<span>x</span></div>
          <div class="stat-label">MTA Certified</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- PROJECTS -->
<div class="section-wrapper" id="projects">
  <section>
    <div class="section-header fade-in">
      <span class="section-tag">// 01</span>
      <h2 class="section-title">Case Studies</h2>
    </div>

    <div class="projects-grid">

      <a href="/combat" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type">Server · Client</span>
            <span class="case-date">March 2026 — Ongoing</span>
          </div>
          <div class="case-title">Combat System — Hitboxes, State Machine & Anti-Cheat</div>
          <div class="case-subtitle">
            A fully server authoritative M1 combo system with critical attacks, blocking, parrying, 
            and endlag per weapon style. Built a custom hitbox module, per-player rate limiter, and state controller 
            to prevent client exploitation. Combo data is synced via remote events, the client only 
            handles input.
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">Server Authoritative</span>
            <span class="tag">State Machine</span>
            <span class="tag">Anti Cheat</span>
            <span class="tag">Functional Programming</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

      <a href="/inventory" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type blue">Datastore · Inventory</span>
            <span class="case-date">December 2025 — Feburary 2026</span>
          </div>
          <div class="case-title">Inventory & Datastore System, Session Locking & Data Safety</div>
          <div class="case-subtitle">
            Inventory system featuring persistent player data with session locking to prevent multi-server conflicts, 
            version migration, deep validation, backup keys, and autosave. Inventory supports 
            stackable/non-stackable items, weight limits, items in world with server-side 
            pickup radius validation, and a fully reactive client UI to display changes.
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">DataStoreService</span>
            <span class="tag">Session Locking</span>
            <span class="tag">Inventory UI</span>
            <span class="tag">OOP</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

      <a href="/weather" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type">Environment · Systems</span>
            <span class="case-date">November 2025 — December 2025</span>
          </div>
          <div class="case-title">Weather & Time-of-Day System: Dynamic World State</div>
          <div class="case-subtitle">
            A full weather cycle system with weighted random weather selection, precipitation 
            particle effects, ambient audio, and sky/atmosphere tweening. Indoor detection disables rain particles via raycast. 
            Snow changes terrain part colors via CollectionService tags & cacheing. All visuals are purely client sided.
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">RunService</span>
            <span class="tag">TweenService</span>
            <span class="tag">Raycasting</span>
            <span class="tag">CollectionService</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

      <a href="/movement" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type blue">Movement · Physics</span>
            <span class="case-date"> November 2025 </span>
          </div>
          <div class="case-title">Movement System: Sprint, Dash, Double Jump & Sliding</div>
          <div class="case-subtitle">
            Server authoritative movement with sprint, directional dashing, double jump, and sliding utilizing 
            LinearVelocity and AlignOrientation. Sliding speed 
            multiplier responds to terrain incline, accelerating downhill and decelerating 
            on flat ground. Client only handles player input and animation playing (Animations were borrowed from toolbox)
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">LinearVelocity</span>
            <span class="tag">AlignOrientation</span>
            <span class="tag">Raycasting</span>
            <span class="tag">Physics</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

      <a href="/dialogue" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type">Dialogue & UI</span>
            <span class="case-date">November 2025</span>
          </div>
          <div class="case-title">Dialogue System: Node-Based Branching NPC Conversations</div>
          <div class="case-subtitle">
            A reusable branching dialogue system driven by node graphs defined in module scripts. 
            Any NPC can use it by giving them a node driven dialogue model. Supports dynamic text injection 
            (player name, display name), scrollable response buttons, and clean server/client 
            separation with a single RemoteEvent.
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">Module Pattern</span>
            <span class="tag">UI Design</span>
            <span class="tag">Node Graph</span>
            <span class="tag">Reusable</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

      <a href="/stats" class="case-card fade-in">
        <div>
          <div class="case-meta">
            <span class="case-type blue">RPG/Stats System</span>
            <span class="case-date">July 2025 - September 2025</span>
          </div>
          <div class="case-title">Stat & Progression System: Races, Levels & Skill Points</div>
          <div class="case-subtitle">
            A basic RPG stat system with weighted race/variant rolling, randomly generated 
            character names by gender, a nonlinear XP curve scaling across 100 levels, 
            and a handcrafted skill point reward table. Stats (Strength, Vitality, Agility, Arcane) 
            are capped and managed through a clean model/controller split.
          </div>
          <div class="case-tags">
            <span class="tag">Lua</span>
            <span class="tag">RPG Design</span>
            <span class="tag">Procedural Generation</span>
            <span class="tag">XP Curve</span>
            <span class="tag">OOP</span>
          </div>
        </div>
        <div class="case-arrow">↗</div>
      </a>

    </div>
  </section>
</div>

<!-- SKILLS -->
<div class="section-wrapper" id="skills">
  <section>
    <div class="section-header fade-in">
      <span class="section-tag">// 02</span>
      <h2 class="section-title">Skills</h2>
    </div>
    <div class="skills-grid">
      <div class="skill-card fade-in">
        <div class="skill-icon">⚙️</div>
        <div class="skill-name">Lua / Luau</div>
        <div class="skill-desc">Primary language. functional programming patterns, module architecture, server-client split.</div>
        <div class="skill-bar-wrap"><div class="skill-bar" style="width:90%"></div></div>
      </div>
      <div class="skill-card fade-in">
        <div class="skill-icon">🔧</div>
        <div class="skill-name">C++</div>
        <div class="skill-desc">Dynamic memory, pointer arithmetic, linked lists, OOP, postfix expression evaluation.</div>
        <div class="skill-bar-wrap"><div class="skill-bar" style="width:70%"></div></div>
      </div>
      <div class="skill-card fade-in">
        <div class="skill-icon">🎮</div>
        <div class="skill-name">Game Systems Architecture</div>
        <div class="skill-desc">Server authoritative design, state machines, anti cheat, physics constraints, hitbox systems.</div>
        <div class="skill-bar-wrap"><div class="skill-bar" style="width:85%"></div></div>
      </div>
      <div class="skill-card fade-in">
        <div class="skill-icon">🗄️</div>
        <div class="skill-name">Database & Persistence</div>
        <div class="skill-desc">DataStore session locking, versioned saves, migration chains, retry logic, backup keys.</div>
        <div class="skill-bar-wrap"><div class="skill-bar" style="width:75%"></div></div>
      </div>
      <div class="skill-card fade-in">
        <div class="skill-icon">🖥️</div>
        <div class="skill-name">UI / UX Design</div>
        <div class="skill-desc">Reactive inventory UIs, HUD systems, dialogue interfaces.</div>
